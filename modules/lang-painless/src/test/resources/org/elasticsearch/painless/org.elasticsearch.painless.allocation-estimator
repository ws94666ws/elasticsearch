# Annotations live on the interface; the implementation allowlists the same methods unannotated. A def call resolves to the
# implementation method, so charging must walk to the annotated interface method (allocation annotation inheritance).
class org.elasticsearch.painless.AllocationInheritanceInterface {
  int inheritedConstant() @allocates[class="org.elasticsearch.painless.AllocationInheritanceObject", method="inheritedConstantEstimate"]
  int inheritedDynamic(int) @allocates[class="org.elasticsearch.painless.AllocationInheritanceObject", method="inheritedDynamicEstimate"]
}

class org.elasticsearch.painless.AllocationInheritanceObject {
  ()
  int inheritedConstant()
  int inheritedDynamic(int)
}

