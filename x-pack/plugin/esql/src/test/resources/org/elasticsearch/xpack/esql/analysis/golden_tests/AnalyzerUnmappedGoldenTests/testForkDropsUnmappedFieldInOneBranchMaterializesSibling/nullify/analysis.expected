Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[@timestamp{r}#0,ASC,LAST], Order[_fork{r}#1,ASC,LAST]]]
  \_Fork[[@timestamp{r}#0, client_ip{r}#2, event_duration{r}#3, message{r}#4, unmapped_message{r}#5, _fork{r}#1]]
    |_Project[[@timestamp{f}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9, unmapped_message{r}#10, _fork{r}#11]]
    | \_Eval[[null[NULL] AS unmapped_message#10]]
    |   \_Eval[[fork1[KEYWORD] AS _fork#11]]
    |     \_Project[[@timestamp{f}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9]]
    |       \_EsRelation[partial_mapping_sample_data][@timestamp{f}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9, unmapped_message{f(MissingEsField)}#12]
    \_Project[[@timestamp{f}#13, client_ip{f}#14, event_duration{f}#15, message{f}#16, unmapped_message{f(MissingEsField)}#17, _fork{r}#18]]
      \_Eval[[fork2[KEYWORD] AS _fork#18]]
        \_Filter[true[BOOLEAN]]
          \_EsRelation[partial_mapping_sample_data][@timestamp{f}#13, client_ip{f}#14, event_duration{f}#15, message{f}#16, unmapped_message{f(MissingEsField)}#17]