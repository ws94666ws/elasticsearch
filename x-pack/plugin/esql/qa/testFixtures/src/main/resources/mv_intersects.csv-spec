mvIntersectsKeywordFields
required_capability: fn_mv_intersects

FROM employees
| WHERE emp_no == 10001
| EVAL intersects = MV_INTERSECTS(job_positions, last_name)
| KEEP emp_no, intersects
;

emp_no:integer | intersects:boolean
10001          | false
;

withBoolean
required_capability: fn_mv_intersects

FROM all_types_mv
| WHERE mv_intersects(boolean, [true])
| SORT id
| KEEP id, boolean
;

id:long | boolean:boolean
2       | [false, true]
3       | [false, true]
4       | [false, true]
5       | [false, true]
;

