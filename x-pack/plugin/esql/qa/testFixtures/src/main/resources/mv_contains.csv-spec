withFoldableEmptyRightArgument
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(keyword, mv_intersection(["foo", "bar"], ["foobar", "abc"]))
| SORT id
| KEEP id, keyword
;

id: long | keyword: keyword
0        | null
1        | key1
2        | ["key1", "key2"]
3        | ["key1", "key2", "key3"]
4        | ["key1", "key2", "key3", "key4"]
5        | ["key1", "key2", "key3", "key4", "key5"]
;

withFoldableEmptyLeftArgument
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(mv_intersection(["foo", "bar"], ["foobar", "abc"]), keyword)
| SORT id
| KEEP id, keyword
;

id: long | keyword: keyword
0        | null
;

