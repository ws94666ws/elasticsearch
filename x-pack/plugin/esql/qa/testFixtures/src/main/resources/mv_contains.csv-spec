withBoolean
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(boolean, ["true", "false"]::boolean)
| SORT id
| KEEP id, boolean
;

id:long | boolean:boolean
2       | [false, true]
3       | [false, true]
4       | [false, true]
5       | [false, true]
;

withBooleanAndNull
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(boolean, NULL) AND id <=3
| SORT id
| KEEP id, boolean
;

id: long | boolean: boolean
0        | null
1        | false
2        | [false, true]
3        | [false, true]
;

