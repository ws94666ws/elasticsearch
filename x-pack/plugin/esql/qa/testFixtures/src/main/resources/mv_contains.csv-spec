withDate
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(date, ["2024-01-03T00:00:00.000Z", "2024-01-04T00:00:00.000Z"]::date)
| SORT id
| KEEP id, date
;

id:long | date:date
4       | ["2024-01-01T00:00:00.000Z", "2024-01-02T00:00:00.000Z", "2024-01-03T00:00:00.000Z", "2024-01-04T00:00:00.000Z"]
5       | ["2024-01-01T00:00:00.000Z", "2024-01-02T00:00:00.000Z", "2024-01-03T00:00:00.000Z", "2024-01-04T00:00:00.000Z", "2024-01-05T00:00:00.000Z"]
;

withDateAndNull
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(date, NULL) AND id <=3
| SORT id
| KEEP id, date
;

id: long | date: date
0        | null
1        | 2024-01-01T00:00:00.000Z
2        | ["2024-01-01T00:00:00.000Z", "2024-01-02T00:00:00.000Z"]
3        | ["2024-01-01T00:00:00.000Z", "2024-01-02T00:00:00.000Z", "2024-01-03T00:00:00.000Z"]
;

withDateNanos
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(date_nanos, ["2024-01-03T00:00:00.000000003Z", "2024-01-04T00:00:00.000000004Z"]::date_nanos)
| SORT id
| KEEP id, date_nanos
;

id:long | date_nanos:date_nanos
4       | ["2024-01-01T00:00:00.000000001Z", "2024-01-02T00:00:00.000000002Z", "2024-01-03T00:00:00.000000003Z", "2024-01-04T00:00:00.000000004Z"]
5       | ["2024-01-01T00:00:00.000000001Z", "2024-01-02T00:00:00.000000002Z", "2024-01-03T00:00:00.000000003Z", "2024-01-04T00:00:00.000000004Z", "2024-01-05T00:00:00.000000005Z"]
;

withDateNanosAndNull
required_capability: fn_mv_contains_v1

FROM all_types_mv
| WHERE mv_contains(date_nanos, NULL) AND id <=3
| SORT id
| KEEP id, date_nanos
;

id: long | date_nanos: date_nanos
0        | null
1        | 2024-01-01T00:00:00.000000001Z
2        | ["2024-01-01T00:00:00.000000001Z", "2024-01-02T00:00:00.000000002Z"]
3        | ["2024-01-01T00:00:00.000000001Z", "2024-01-02T00:00:00.000000002Z", "2024-01-03T00:00:00.000000003Z"]
;

